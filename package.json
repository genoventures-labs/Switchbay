{
  "name": "@genoventures/switchbay",
  "version": "1.6.337",
  "description": "Terminal-first AI coding workbench with cloud/local model lanes and MCP bridge",
  "module": "./dist/client/index.js",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "switchbay": "./bin/switchbay"
  },
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "bin", "README.md", "docs/LOCAL_API_README.md", "web/dist"],
  "sideEffects": false,
  "scripts": {
    "build": "bun run build:client && bun run web:build && bun build index.tsx --compile --outfile bin/switchbay-native",
    "build:client": "bun build src/client/index.ts --target browser --outdir dist/client && bunx tsc -p tsconfig.client.json",
    "web:dev": "bun run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "test": "bun test",
    "postinstall": "bun scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/genoventures-labs/Switchbay.git"
  },
  "keywords": ["ai", "coding-agent", "terminal", "cli", "developer-tools", "mcp", "ollama", "openai", "anthropic"],
  "engines": {
    "bun": ">=1.0.0"
  }
}
